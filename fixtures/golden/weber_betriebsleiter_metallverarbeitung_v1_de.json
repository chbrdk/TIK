        }
      },
      "lines": [
        {
          "text": "Dieter sitzt in der Küche, Kaffee wird kalt. Sein Tablet leuchtet auf — echeon zeigt den Shopfloor, auch wenn er noch zu Hause ist.",
          "at_sec": 0,
          "pause_after_sec": 2
        },
        {
          "text": "Linie 3: 23 Minuten Stillstand gestern. Grund: unklar. Das ist die Art von Information, die den Morgen sofort verändern kann.",
          "at_sec": 4.5,
          "pause_after_sec": 2.5
        },
        {
          "text": "Dieter kennt jeden Stillstand. Er kennt auch den Preis. Jede Minute ist sichtbar, jetzt sofort, noch bevor er sein Auto startet.",
          "at_sec": 9.5,
          "pause_after_sec": 3
        }
      ],
      "estimated_duration_sec": 16,
      "cues": [
        {
