      "ui_overlay": null,
      "lines": [
        {
          "text": "Der Tag ist vorbei. Die Daten liegen vor mir.",
          "at_sec": 2,
          "pause_after_sec": 1.5
        },
        {
          "text": "OEE 78 Prozent. Nicht schlecht, aber nicht gut genug.",
          "at_sec": 5.5,
          "pause_after_sec": 2
        },
        {
          "text": "Und da — Linie 3. Verschmutzungs-Fehler. Alle zwei Wochen. Immer zur gleichen Zeit.",
          "at_sec": 9.5,
          "pause_after_sec": 2.5
        },
        {
          "text": "Das habe ich gefühlt. Jetzt kann ich es beweisen.",
          "at_sec": 13.5,
          "pause_after_sec": 2
        },
        {
          "text": "Die Wartung muss anders rhythmisiert werden. Präventiv, nicht reaktiv.",
          "at_sec": 17.5,
          "pause_after_sec": 1.5
        },
        {
          "text": "Dieter Hoffmann, du weißt jetzt, wo es weh tut. Und wie man es heilt.",
          "at_sec": 21,
          "pause_after_sec": 2
        },
        {
          "text": "Nächste Woche mit dem Schichtleiter. Ein Plan entsteht.",
          "at_sec": 25,
          "pause_after_sec": 1
