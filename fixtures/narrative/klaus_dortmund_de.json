      "estimated_duration_sec": 12,
      "lines": [
        { "text": "Willkommen bei Persona Reality.", "at_sec": 0, "pause_after_sec": 0.5 },
        {
          "text": "Gleich wirst du jemand anderem — Klaus Berger, Hausverwalter aus Dortmund.",
          "at_sec": 4,
          "pause_after_sec": 0.5
        },
        { "text": "Schau in den Spiegel. Das ist dein Morgen.", "at_sec": 9, "pause_after_sec": 0.6 }
      ]
    },
    "nova_de_act2_01": {
      "speaker": "nova",
      "estimated_duration_sec": 18,
      "lines": [
        { "text": "Sieben Uhr — Küche in deinem MFH in Dortmund.", "at_sec": 0, "pause_after_sec": 0.5 },
        {
          "text": "Die Nebenkostenabrechnung liegt noch auf dem Tisch.",
          "at_sec": 5,
          "pause_after_sec": 0.5
        },
        {
          "text": "Dein Handy vibriert. Der Tag beginnt mit Informationen.",
          "at_sec": 11,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act2_02": {
      "speaker": "nova",
      "estimated_duration_sec": 20,
      "lines": [
        {
          "text": "Das ist dein echeon-Feed — kuratiert für Verwalter wie dich.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "Förderungen, SHK-News, alles was deine Eigentümer beschäftigt.",
          "at_sec": 6,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act3_01": {
      "speaker": "nova",
      "estimated_duration_sec": 15,
      "lines": [
        {
          "text": "Vormittag im Homeoffice — zwischen E-Mails und Abrechnungen.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "CHECKION zeigt dir, wie sichtbar deine Verwaltung online ist.",
          "at_sec": 6,
          "pause_after_sec": 0.5
        },
        { "text": "Schau auf den Monitor links.", "at_sec": 11, "pause_after_sec": 0.6 }
      ]
    },
    "nova_de_act3_02": {
      "speaker": "nova",
      "estimated_duration_sec": 12,
      "lines": [
        {
          "text": "GEO-Sichtbarkeit, Ranking, Website-Score — auf einen Blick.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "So erleben Auftraggeber deine digitale Präsenz.",
          "at_sec": 5,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act4_01": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Abend. Du lässt den Tag auf dem Sofa ausklingen.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "AUDION macht sichtbar, was dich wirklich beschäftigt.",
          "at_sec": 5,
          "pause_after_sec": 0.5
        },
        {
          "text": "Compliance, Entscheidungsdruck — nicht abstrakt, sondern hier im Raum.",
          "at_sec": 10,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act5_01": {
      "speaker": "nova",
      "estimated_duration_sec": 18,
      "lines": [
        {
          "text": "Du hast Klaus Berger fünf Minuten lang erlebt.",
