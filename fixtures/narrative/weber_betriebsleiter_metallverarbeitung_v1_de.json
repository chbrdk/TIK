{
  "meta": {
    "persona_id": "weber_betriebsleiter_metallverarbeitung_v1",
    "language": "de",
    "schema_version": "1.0"
  },
  "voiceover_tracks": {
    "nova_de_act1_01": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Dieter Hoffmann. Betriebsleiter. Werksleiter Metallverarbeitung.",
          "at_sec": 2,
          "pause_after_sec": 1.5
        },
        {
          "text": "Dieter Hoffmann, 48 Jahre. Betriebsleiter, Werksleiter Metallverarbeitung. Weber Antriebstechnik GmbH.",
          "at_sec": 5.5,
          "pause_after_sec": 2
        },
        {
          "text": "Jede Entscheidung kostet Zeit oder Geld.",
          "at_sec": 9.5,
          "pause_after_sec": 1
        },
        {
          "text": "Welche wählst du?",
          "at_sec": 11.5,
          "pause_after_sec": 3
        }
      ]
    },
    "nova_de_act2_01": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Dieter sitzt in der Küche, Kaffee wird kalt. Sein Tablet leuchtet auf — echeon zeigt den Shopfloor, auch wenn er noch zu Hause ist.",
          "at_sec": 0,
          "pause_after_sec": 2
        },
        {
          "text": "Linie 3: 23 Minuten Stillstand gestern. Grund: unklar. Das ist die Art von Information, die den Morgen sofort verändern kann.",
          "at_sec": 4.5,
          "pause_after_sec": 2.5
        },
        {
          "text": "Dieter kennt jeden Stillstand. Er kennt auch den Preis. Jede Minute ist sichtbar, jetzt sofort, noch bevor er sein Auto startet.",
          "at_sec": 9.5,
          "pause_after_sec": 3
        }
      ]
    },
    "nova_de_act3_01": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Dieter Hoffmann betritt die Halle. Die Maschinen laufen, die Schicht ist in vollem Gange.",
          "at_sec": 0
        },
        {
          "text": "Er spricht mit dem Schichtleiter: ‚Was ist gestern bei der Störung los gewesen?'",
          "at_sec": 4
        },
        {
          "text": "Der Schichtleiter zeigt auf dem checkion-Terminal: ‚Hier – Sensor-Fehler erkannt um 22:47. Ursache: Verschmutzung. Wir haben's nachts noch repariert.'",
          "at_sec": 9,
          "pause_after_sec": 2
        },
        {
          "text": "Die Transparenz ist plötzlich da. Dieter Hoffmann sieht, dass die Fehlserie hätte vermieden werden können.",
          "at_sec": 13
        },
        {
          "text": "Eine schnelle Reaktion hätte Zeit und Material gespart. Aber wer hätte es gewusst – ohne diese Daten?",
          "at_sec": 18
        },
        {
          "text": "checkion zeigt nicht nur das Problem, sondern auch, wie teuer die Verzögerung war.",
          "at_sec": 23,
          "pause_after_sec": 1
        },
        {
          "text": "Das ist die Last der Transparenz: Entscheidungen werden sichtbar. Und jede Sekunde zählt.",
          "at_sec": 26
        }
      ]
    },
    "nova_de_act4_04": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Der Tag ist vorbei. Die Daten liegen vor mir.",
          "at_sec": 2,
          "pause_after_sec": 1.5
        },
        {
          "text": "OEE 78 Prozent. Nicht schlecht, aber nicht gut genug.",
          "at_sec": 5.5,
          "pause_after_sec": 2
        },
        {
          "text": "Und da — Linie 3. Verschmutzungs-Fehler. Alle zwei Wochen. Immer zur gleichen Zeit.",
          "at_sec": 9.5,
          "pause_after_sec": 2.5
        },
        {
          "text": "Das habe ich gefühlt. Jetzt kann ich es beweisen.",
          "at_sec": 13.5,
          "pause_after_sec": 2
        },
        {
          "text": "Die Wartung muss anders rhythmisiert werden. Präventiv, nicht reaktiv.",
          "at_sec": 17.5,
          "pause_after_sec": 1.5
        },
        {
          "text": "Dieter Hoffmann, du weißt jetzt, wo es weh tut. Und wie man es heilt.",
          "at_sec": 21,
          "pause_after_sec": 2
        },
        {
          "text": "Nächste Woche mit dem Schichtleiter. Ein Plan entsteht.",
          "at_sec": 25,
          "pause_after_sec": 1
        }
      ]
    },
    "nova_de_act5_01": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Eine Schicht ist vorbei. Dieter Hoffmann, Betriebsleiter bei Weber Antriebstechnik GmbH, hält in diesem Moment alle Fäden in der Hand.",
          "at_sec": 0,
          "pause_after_sec": 1.5
        },
        {
          "text": "Die echeon-Alerts vom Morgen. Die checkion-Befunde vom Mittag. Die audion-Erkenntnisse vom Abend.",
          "at_sec": 3,
          "pause_after_sec": 2
        },
        {
          "text": "Jeder Datenpunkt ist eine Antwort. Jede Antwort führt zu einer besseren Frage.",
          "at_sec": 7,
          "pause_after_sec": 1.5
        },
        {
          "text": "Morgen wird er es besser wissen. Nicht weil er alles perfekt macht, sondern weil er heute sieht, was möglich ist.",
          "at_sec": 10,
          "pause_after_sec": 2
        },
        {
          "text": "Ein Lichtstern erscheint — eine Einladung, tiefer einzusteigen. Nicht in neue Technologie um der Technologie willen.",
          "at_sec": 14,
          "pause_after_sec": 1.5
        },
        {
          "text": "Sondern in die Kontinuität: echeon, checkion, audion — ein Kreis, der sich morgen aufs Neue öffnet.",
          "at_sec": 17,
          "pause_after_sec": 2
        },
        {
          "text": "Die Reise endet hier nicht. Sie wird nur tiefer.",
          "at_sec": 21,
          "pause_after_sec": 1
        }
      ]
    }
  },
