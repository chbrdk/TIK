{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://msqdx.de/schemas/persona-reality/act_blueprint.v1.schema.json",
  "title": "Persona Reality Act Blueprint",
  "description": "Agent output contract for one act: story, speech, image prompts, metrics, cues.",
  "type": "object",
  "required": [
    "meta",
    "act",
    "story",
    "environment",
    "image_prompts",
    "voiceover",
    "interaction",
    "data_viz",
    "timeline"
  ],
  "additionalProperties": false,
  "properties": {
    "meta": { "$ref": "#/$defs/Meta" },
    "act": { "type": "integer", "minimum": 1, "maximum": 5 },
    "story": { "$ref": "#/$defs/Story" },
    "environment": { "$ref": "#/$defs/EnvironmentSpec" },
    "image_prompts": { "$ref": "#/$defs/ImagePrompts" },
    "voiceover": { "$ref": "#/$defs/VoiceoverSpec" },
    "interaction": { "$ref": "#/$defs/InteractionSpec" },
    "data_viz": { "$ref": "#/$defs/DataVizSpec" },
    "timeline": { "$ref": "#/$defs/TimelineSpec" }
  },
  "$defs": {
    "Meta": {
      "type": "object",
      "required": ["blueprint_id", "schema_version", "language"],
      "additionalProperties": false,
      "properties": {
        "blueprint_id": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "const": "1.0" },
        "language": { "type": "string", "enum": ["de", "en"] },
        "product_layer": {
          "type": "string",
          "enum": ["onboarding", "echeon", "checkion", "audion", "closure"]
        }
      }
    },
    "Story": {
      "type": "object",
      "required": ["core_message_de", "core_message_en", "user_feeling", "nova_role"],
      "additionalProperties": false,
      "properties": {
        "core_message_de": { "type": "string", "minLength": 1 },
        "core_message_en": { "type": "string", "minLength": 1 },
        "user_feeling": { "type": "string", "minLength": 1 },
        "nova_role": { "type": "string", "minLength": 1 }
      }
    },
    "EnvironmentSpec": {
      "type": "object",
      "required": [
        "environment_id",
        "world_slug",
        "scene_concept_de",
        "setting_class",
        "time_of_day",
        "lighting_preset"
      ],
      "additionalProperties": false,
      "properties": {
        "environment_id": { "type": "string", "pattern": "^env_[a-z0-9_]+$" },
        "world_slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "scene_concept_de": { "type": "string", "minLength": 20 },
        "setting_class": { "type": "string", "minLength": 1 },
        "style_hint": { "type": "string" },
        "region_hint": { "type": "string" },
        "time_of_day": { "type": "string" },
        "lighting_preset": {
          "type": "string",
          "enum": [
            "morning_warm",
            "midday_neutral",
            "afternoon_golden",
            "evening_warm",
            "night_cool",
            "void_minimal"
          ]
        }
      }
    },
    "ImagePrompts": {
      "type": "object",
      "required": ["splat_world"],
      "additionalProperties": false,
      "properties": {
        "splat_world": { "$ref": "#/$defs/SplatPrompt" },
        "storyblok_page": { "$ref": "#/$defs/StoryblokPrompt" },
        "prop_notes": { "type": "string" }
      }
    },
    "SplatPrompt": {
      "type": "object",
      "required": ["slug_hint", "prompt_en", "negative_prompt"],
      "additionalProperties": false,
      "properties": {
        "slug_hint": { "type": "string" },
        "prompt_en": { "type": "string", "minLength": 20 },
        "negative_prompt": { "type": "string" },
        "camera_notes": { "type": "string" },
        "anchor_placements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["anchor_id", "description"],
            "properties": {
              "anchor_id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "StoryblokPrompt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "variant_a_personalized": { "type": "string" },
        "variant_b_generic": { "type": "string" }
      }
    },
    "VoiceoverSpec": {
      "type": "object",
      "required": ["pre_beat_tracks", "beat_track"],
      "additionalProperties": false,
      "properties": {
        "pre_beat_tracks": {
          "type": "array",
          "items": { "$ref": "#/$defs/TrackTemplate" }
        },
        "beat_track": { "$ref": "#/$defs/TrackTemplate" }
      }
    },
    "TrackTemplate": {
      "type": "object",
      "required": ["track_id_suffix", "lines"],
      "additionalProperties": false,
      "properties": {
        "track_id_suffix": {
          "type": "string",
          "pattern": "^[0-9]{2}$",
          "description": "e.g. 01 → nova_de_act3_01"
        },
        "estimated_duration_sec": { "type": "number", "minimum": 4 },
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/LineTemplate" }
        }
      }
    },
    "LineTemplate": {
      "type": "object",
      "required": ["text", "at_sec"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Supports {{persona.display_name}} etc."
        },
        "at_sec": { "type": "number", "minimum": 0 },
        "pause_after_sec": { "type": "number", "minimum": 0 }
      }
    },
    "InteractionSpec": {
      "type": "object",
      "required": ["trigger_type", "primary_anchor"],
      "additionalProperties": false,
      "properties": {
        "trigger_type": {
          "type": "string",
          "enum": [
            "timer",
            "look_at",
            "pickup",
            "sit_down",
            "stand_up",
            "scene_enter",
            "ui_interact"
          ]
        },
        "trigger_target": { "type": ["string", "null"] },
        "primary_anchor": { "type": "string" },
        "delay_sec": { "type": "number", "minimum": 0 },
        "haptic_pattern": {
          "type": "string",
          "enum": ["none", "soft_pulse", "double_tap", "alert"]
        }
      }
    },
    "DataVizSpec": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["none", "echeon_feed", "checkion_chart", "audion_diegetic", "qr_closure"]
        },
        "echeon_feed": {
          "type": "object",
          "properties": {
            "item_count": { "type": "integer", "minimum": 1, "maximum": 6 },
            "categories": { "type": "array", "items": { "type": "string" } },
            "headline_templates": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "checkion_chart": {
          "type": "object",
          "properties": {
            "chart_type": { "type": "string", "enum": ["bar_3d", "bar_2d"] },
            "metrics": {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "items": { "$ref": "#/$defs/MetricTemplate" }
            }
          }
        },
        "audion_diegetic": {
          "type": "object",
          "properties": {
            "metrics": {
              "type": "array",
              "items": { "$ref": "#/$defs/DiegeticMetricTemplate" }
            }
          }
        },
        "qr_closure": {
          "type": "object",
          "properties": {
            "anchor_object": { "type": "string", "default": "qr_panel" }
          }
        }
      }
    },
    "MetricTemplate": {
      "type": "object",
      "required": ["label", "value", "unit"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "comparison_value": { "type": ["number", "null"] },
        "trend": { "type": "string", "enum": ["up", "down", "flat"] },
        "rationale_de": { "type": "string" }
      }
    },
    "DiegeticMetricTemplate": {
      "type": "object",
      "required": ["metric_id", "label", "value", "anchor_object", "animation_preset"],
      "additionalProperties": false,
      "properties": {
        "metric_id": { "type": "string" },
        "label": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "anchor_object": { "type": "string" },
        "animation_preset": {
          "type": "string",
          "enum": ["glow_warm", "pulse_red", "flicker", "color_shift", "particle_burst", "scale_breath"]
        },
        "rationale_de": { "type": "string" }
      }
    },
    "TimelineSpec": {
      "type": "object",
      "required": ["target_duration_sec", "pre_beat_cues", "beat_cue_templates"],
      "additionalProperties": false,
      "properties": {
        "target_duration_sec": { "type": "number", "minimum": 10 },
        "ambient_audio_id": { "type": ["string", "null"] },
        "pre_beat_cues": {
          "type": "array",
          "items": { "$ref": "#/$defs/CueTemplate" }
        },
        "beat_cue_templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/CueTemplate" }
        }
      }
    },
    "CueTemplate": {
      "type": "object",
      "required": ["type", "at_sec"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "at_sec": { "type": "number", "minimum": 0 },
        "delay_from_beat": { "type": "boolean" },
        "track_id": { "type": "string" },
        "anchor_object": { "type": "string" },
        "metric_id": { "type": "string" },
        "animation_preset": { "type": "string" },
        "ambient_audio_id": { "type": "string" },
        "action": { "type": "string", "enum": ["start", "stop"] },
        "duration_sec": { "type": "number", "minimum": 0 },
        "mode": { "type": "string", "enum": ["in", "out"] },
        "pattern": { "type": "string" }
      }
    }
  }
}
