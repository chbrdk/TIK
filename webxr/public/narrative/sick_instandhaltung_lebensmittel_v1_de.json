{
  "meta": {
    "persona_id": "sick_instandhaltung_lebensmittel_v1",
    "language": "de",
    "schema_version": "1.0"
  },
  "voiceover_tracks": {
    "nova_de_act1_01": {
      "speaker": "nova",
      "estimated_duration_sec": 16,
      "lines": [
        {
          "text": "Willkommen bei Persona Reality.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "Gleich wirst du jemand anderem — Thomas Berger, Leiter Instandhaltung in Regensburg.",
          "at_sec": 4,
          "pause_after_sec": 0.5
        },
        {
          "text": "Schau in den Spiegel. Dein Stör- und Audit-Tag an der Abfülllinie beginnt jetzt.",
          "at_sec": 9,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act2_01": {
      "speaker": "nova",
      "estimated_duration_sec": 22,
      "lines": [
        {
          "text": "Kurz vor sechs — Abfüllhalle in Regensburg. Die Linie steht.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "Rote Meldung am HMI. IFS-Audit in zwei Tagen. Jede Minute zählt.",
          "at_sec": 6,
          "pause_after_sec": 0.5
        },
        {
          "text": "Am Wartungswagen wartet dein Tablet. Der Tag beginnt mit Informationen.",
          "at_sec": 14,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act2_02": {
      "speaker": "nova",
      "estimated_duration_sec": 22,
      "lines": [
        {
          "text": "Das ist dein echeon-Feed — kuratiert für Leiter Instandhaltung wie dich.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "Stillstände, Sensorik, Audit-Vorbereitung — was Food-Produktion heute bewegt.",
          "at_sec": 6,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act3_01": {
      "speaker": "nova",
      "estimated_duration_sec": 18,
      "lines": [
        {
          "text": "Halb zwölf — Leitstand. Die Linie steht noch. Schichtbuch offen.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "CHECKION zeigt, wie sichtbar dein Werk und SICK AG im Fachsegment online sind.",
          "at_sec": 6,
          "pause_after_sec": 0.5
        },
        {
          "text": "Schau auf den Wandmonitor.",
          "at_sec": 14,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act3_02": {
      "speaker": "nova",
      "estimated_duration_sec": 14,
      "lines": [
        {
          "text": "Betriebs-Sichtbarkeit, Lieferanten-Ranking, Technik-Content-Score — auf einen Blick.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "So erleben Produktionsleitung und Zulieferer eure digitale Präsenz.",
          "at_sec": 6,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act4_01": {
      "speaker": "nova",
      "estimated_duration_sec": 14,
      "lines": [
        {
          "text": "Spätabend im CIP-Raum. Der Reinigungszyklus läuft länger als geplant — die Linie bleibt still.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "Setz dich. Hier wird die Last greifbar — am Panel und in den Audit-Ordnern.",
          "at_sec": 7,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act4_02": {
      "speaker": "nova",
      "estimated_duration_sec": 14,
      "lines": [
        {
          "text": "AUDION macht sichtbar, was dich wirklich beschäftigt.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "Ausfallrisiko, Audit-Druck — nicht abstrakt, sondern hier im Raum.",
          "at_sec": 5,
          "pause_after_sec": 0.6
        }
      ]
    },
    "nova_de_act5_01": {
      "speaker": "nova",
      "estimated_duration_sec": 22,
      "lines": [
        {
          "text": "Du hast Thomas Berger fünf Minuten lang erlebt.",
          "at_sec": 0,
          "pause_after_sec": 0.5
        },
        {
          "text": "echeon, CHECKION, AUDION — ein Stör- und Audit-Tag aus seiner Perspektive.",
          "at_sec": 5,
          "pause_after_sec": 0.5
        },
        {
          "text": "Scanne den Code — dein Report für SICK AG wartet.",
          "at_sec": 12,
          "pause_after_sec": 0.6
        }
      ]
    }
  },
