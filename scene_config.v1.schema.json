{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://msqdx.de/schemas/persona-reality/scene_config.v1.schema.json",
  "title": "Persona Reality Scene Config",
  "description": "Runtime contract between AUDION session composer and Unity SceneConfigLoader. Version 1.0.",
  "type": "object",
  "required": ["meta", "persona", "avatar", "environments", "narrative_beats", "data_layers", "report"],
  "additionalProperties": false,
  "properties": {
    "meta": { "$ref": "#/$defs/Meta" },
    "persona": { "$ref": "#/$defs/Persona" },
    "avatar": { "$ref": "#/$defs/Avatar" },
    "environments": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/EnvironmentBinding" }
    },
    "narrative_beats": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/NarrativeBeat" }
    },
    "data_layers": { "$ref": "#/$defs/DataLayers" },
    "brand_layer": {
      "oneOf": [{ "$ref": "#/$defs/BrandLayer" }, { "type": "null" }]
    },
    "report": { "$ref": "#/$defs/ReportRef" }
  },
  "$defs": {
    "Meta": {
      "type": "object",
      "required": ["scene_id", "persona_id", "generated_at", "duration_sec", "language", "schema_version"],
      "additionalProperties": false,
      "properties": {
        "scene_id": { "type": "string", "minLength": 1 },
        "persona_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "generated_at": { "type": "string", "format": "date-time" },
        "duration_sec": { "type": "integer", "minimum": 60, "maximum": 600, "default": 300 },
        "language": { "type": "string", "enum": ["de", "en"] },
        "client_id": { "type": ["string", "null"] },
        "schema_version": { "type": "string", "const": "1.0" }
      }
    },
    "PersonaAxes": {
      "type": "object",
      "required": ["sector", "life_stage", "tech_affinity", "decision_style", "industry"],
      "additionalProperties": false,
      "properties": {
        "sector": {
          "type": "string",
          "enum": [
            "b2c_mass",
            "b2c_premium",
            "b2c_lifestyle",
            "b2b_smb_decision_maker",
            "b2b_enterprise_buyer",
            "b2b_specialist",
            "b2b_c_level"
          ]
        },
        "life_stage": {
          "type": "string",
          "enum": ["young_pro", "family_phase", "established_career", "empty_nester", "retiree"]
        },
        "tech_affinity": {
          "type": "string",
          "enum": ["early_adopter", "mainstream", "skeptic"]
        },
        "decision_style": {
          "type": "string",
          "enum": ["rational", "emotional", "social_proof", "status"]
        },
        "industry": { "type": "string", "minLength": 1 }
      }
    },
    "Persona": {
      "type": "object",
      "required": ["id", "display_name", "axes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "display_name": { "type": "string", "minLength": 1 },
        "age": { "type": "integer", "minimum": 18, "maximum": 99 },
        "gender_expression": { "type": "string", "enum": ["male", "female", "androgynous"] },
        "location": { "type": "string" },
        "occupation": { "type": "string" },
        "household": { "type": "string" },
        "income_band": {
          "type": "string",
          "enum": ["low", "mid", "upper_mid", "high", "uhnw"]
        },
        "axes": { "$ref": "#/$defs/PersonaAxes" },
        "pain_points": {
          "type": "array",
          "maxItems": 5,
          "items": { "type": "string" }
        },
        "decision_drivers": {
          "type": "array",
          "maxItems": 5,
          "items": { "type": "string" }
        }
      }
    },
    "Avatar": {
      "type": "object",
      "required": ["rpm_avatar_id", "voice_id_elevenlabs"],
      "additionalProperties": false,
      "properties": {
        "rpm_avatar_id": { "type": "string", "minLength": 1 },
        "voice_id_elevenlabs": { "type": "string", "minLength": 1 },
        "outfit_preset": {
          "type": "string",
          "enum": ["business_casual", "blue_collar", "leisure", "premium_casual", "uniform"]
        }
      }
    },
    "EnvironmentBinding": {
      "type": "object",
      "required": ["act", "environment_id", "lighting_preset", "time_of_day"],
      "additionalProperties": false,
      "properties": {
        "act": { "type": "integer", "minimum": 1, "maximum": 5 },
        "environment_id": { "type": "string", "pattern": "^env_[a-z0-9_]+$" },
        "lighting_preset": {
          "type": "string",
          "enum": [
            "morning_warm",
            "midday_neutral",
            "afternoon_golden",
            "evening_warm",
            "night_cool",
            "void_minimal"
          ]
        },
        "time_of_day": { "type": "string" },
        "weather": { "type": "string", "default": "clear" },
        "skybox_id": { "type": ["string", "null"] }
      }
    },
    "NarrativeBeat": {
      "type": "object",
      "required": ["act", "trigger_type", "voiceover_track_id"],
      "additionalProperties": false,
      "properties": {
        "act": { "type": "integer", "minimum": 1, "maximum": 5 },
        "trigger_type": {
          "type": "string",
          "enum": [
            "timer",
            "look_at",
            "pickup",
            "sit_down",
            "stand_up",
            "scene_enter",
            "ui_interact"
          ]
        },
        "trigger_target": { "type": ["string", "null"] },
        "delay_sec": { "type": "number", "minimum": 0, "default": 0 },
        "duration_sec": { "type": "number", "minimum": 0 },
        "voiceover_track_id": { "type": "string", "pattern": "^nova_(de|en)_act[1-5]_[0-9]{2}$" },
        "ambient_audio_id": { "type": ["string", "null"] },
        "haptic_pattern": {
          "type": "string",
          "enum": ["none", "soft_pulse", "double_tap", "alert"],
          "default": "none"
        },
        "ui_overlay": {
          "oneOf": [{ "$ref": "#/$defs/UiOverlay" }, { "type": "null" }]
        }
      }
    },
    "UiOverlay": {
      "type": "object",
      "required": ["type", "anchor_object"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["news_feed", "dashboard", "notification", "metric_badge", "qr_code"]
        },
        "anchor_object": { "type": "string" },
        "payload": { "type": "object", "additionalProperties": true }
      }
    },
    "DataLayers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "echeon": { "$ref": "#/$defs/EcheonLayer" },
        "checkion": { "$ref": "#/$defs/CheckionSnapshot" },
        "audion": { "$ref": "#/$defs/AudionLayer" },
        "storyblok": { "$ref": "#/$defs/StoryblokLayer" }
      }
    },
    "EcheonLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "feed_items": {
          "type": "array",
          "items": { "$ref": "#/$defs/EcheonFeedItem" }
        },
        "cache_ttl_sec": { "type": "integer", "default": 3600 }
      }
    },
    "EcheonFeedItem": {
      "type": "object",
      "required": ["headline", "source", "category", "relevance_score"],
      "additionalProperties": false,
      "properties": {
        "headline": { "type": "string" },
        "source": { "type": "string" },
        "category": { "type": "string" },
        "relevance_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "published_at": { "type": "string", "format": "date-time" },
        "url": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "CheckionSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/CheckionMetric" }
        }
      }
    },
    "CheckionMetric": {
      "type": "object",
      "required": ["label", "value"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "comparison_value": { "type": ["number", "null"] },
        "trend": { "type": "string", "enum": ["up", "down", "flat"] }
      }
    },
    "AudionLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "diegetic_metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/DiegeticMetric" }
        }
      }
    },
    "DiegeticMetric": {
      "type": "object",
      "required": ["metric_id", "value", "anchor_object", "animation_preset"],
      "additionalProperties": false,
      "properties": {
        "metric_id": { "type": "string" },
        "label": { "type": "string" },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "anchor_object": { "type": "string" },
        "animation_preset": {
          "type": "string",
          "enum": [
            "glow_warm",
            "pulse_red",
            "flicker",
            "color_shift",
            "particle_burst",
            "scale_breath"
          ]
        }
      }
    },
    "StoryblokLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "page_variant_a_texture": { "type": "string", "format": "uri" },
        "page_variant_b_texture": { "type": "string", "format": "uri" }
      }
    },
    "BrandLayer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "client_id": { "type": "string" },
        "logo_texture": { "type": "string", "format": "uri" },
        "color_primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "color_secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "props_swap": {
          "type": "array",
          "items": { "$ref": "#/$defs/PropSwap" }
        }
      }
    },
    "PropSwap": {
      "type": "object",
      "required": ["from_asset", "to_asset"],
      "additionalProperties": false,
      "properties": {
        "from_asset": { "type": "string" },
        "to_asset": { "type": "string" }
      }
    },
    "ReportRef": {
      "type": "object",
      "required": ["qr_url", "report_id"],
      "additionalProperties": false,
      "properties": {
        "qr_url": { "type": "string", "format": "uri" },
        "report_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
